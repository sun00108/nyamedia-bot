DATABASE_URL=db/devdb.sqlite3
TELOXIDE_TOKEN=your_telegram_bot_token
DISABLED_USERS=114514,114515
WEBHOOK_BIND_ADDRESS=127.0.0.1
WEBHOOK_BIND_PORT=3000
WEBHOOK_NOTIFY_CHAT=114514,-114514
EMBY_URL=
EMBY_COPY_FROM_USER_ID=
EMBY_TOKEN=

# CLI login settings
CLI_AUTH_ALLOWED_CLIENT_IDS=nyaupload-cli
CLI_AUTH_CODE_SECRET=replace_with_a_long_random_secret
CLI_ACCESS_TOKEN_SECRET=replace_with_a_different_long_random_secret

# Microsoft OneDrive upload session settings
MICROSOFT_CLIENT_ID=your_microsoft_app_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_app_client_secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost/callback
MICROSOFT_SESSION_FILE=onedrive-session.json
MICROSOFT_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
MICROSOFT_OAUTH_BASE_URL=https://login.microsoftonline.com

# Telegram Web App settings
WEB_REDIRECT_URL=https://your-domain.com/
BOT_USERNAME=your_bot_username

# Frontend build environment variables (used by Vite)
VITE_BOT_USERNAME=your_bot_username
VITE_REDIRECT_URL=https://your-domain.com/

# Media scraping API settings
TMDB_ACCESS_TOKEN=your_tmdb_access_token
BGM_ACCESS_TOKEN=your_bgm_access_token
